# Copy this file to .env (or .env.local) and fill in real values.
# Never commit the filled-in file -- .env* is gitignored.

# --- Database (Prisma + Postgres) ---------------------------------------
# Local dev: run `npx prisma dev --name xp-league-local --detach` and use
# the DATABASE_URL/SHADOW_DATABASE_URL it prints (see CLAUDE.md).
# Production: Neon's pooled connection string.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
SHADOW_DATABASE_URL="postgresql://user:password@host:5432/dbname_shadow?sslmode=require"

# --- Auth.js --------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-with-a-random-32-byte-base64-secret"
AUTH_TRUST_HOST="true"

# Email provider (Resend) -- magic-link sign-in. If unset in development,
# the sign-in link is logged to the server console instead of emailed.
AUTH_RESEND_KEY=""
EMAIL_FROM="XP League <onboarding@resend.dev>"

# --- Phase 2/3 -- not yet wired up, reserved names -----------------------
# File/video storage (Cloudflare R2) for the Clips feature
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""

# Stripe subscriptions for the paid tier
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Error monitoring
# SENTRY_DSN=""
